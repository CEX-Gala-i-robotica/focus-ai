<Window x:Class="focus_ai.SignUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus AI - Sign Up"
        Height="660"
        Width="420"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Color x:Key="LightWindowBg">#4285F4</Color>
        <Color x:Key="LightCardBg">#FFFFFF</Color>
        <Color x:Key="LightTextPrimary">#1A1A1A</Color>
        <Color x:Key="LightTextSecondary">#666666</Color>
        <Color x:Key="LightBorder">#E5E5E5</Color>
        <Color x:Key="LightInputBg">#FFFFFF</Color>
        <Color x:Key="LightDivider">#E5E5E5</Color>

        <Color x:Key="DarkWindowBg">#0F0F0F</Color>
        <Color x:Key="DarkCardBg">#1C1C1E</Color>
        <Color x:Key="DarkTextPrimary">#F5F5F5</Color>
        <Color x:Key="DarkTextSecondary">#999999</Color>
        <Color x:Key="DarkBorder">#3A3A3C</Color>
        <Color x:Key="DarkInputBg">#2C2C2E</Color>
        <Color x:Key="DarkDivider">#3A3A3C</Color>

        <SolidColorBrush x:Key="CardBgBrush"      Color="{StaticResource LightCardBg}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource LightTextPrimary}"/>
        <SolidColorBrush x:Key="TextSecBrush"     Color="{StaticResource LightTextSecondary}"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource LightBorder}"/>
        <SolidColorBrush x:Key="InputBgBrush"     Color="{StaticResource LightInputBg}"/>
        <SolidColorBrush x:Key="DividerBrush"     Color="{StaticResource LightDivider}"/>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
    </Window.Resources>

    <Window.Background>
        <SolidColorBrush x:Name="WindowBackground" Color="{StaticResource LightWindowBg}"/>
    </Window.Background>

    <Grid>
        <Border Width="360"
                CornerRadius="20"
                Padding="30"
                Background="{DynamicResource CardBgBrush}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect x:Name="CardShadow"
                                  BlurRadius="25" ShadowDepth="0"
                                  Opacity="0.15" Color="#000000"/>
            </Border.Effect>

            <StackPanel>
                <StackPanel.RenderTransform>
                    <TranslateTransform Y="20"/>
                </StackPanel.RenderTransform>
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.4"/>
                                <DoubleAnimation Storyboard.TargetProperty="(StackPanel.RenderTransform).(TranslateTransform.Y)"
                                                 From="20" To="0" Duration="0:0:0.4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>

                <TextBlock Text="Creează cont"
                           FontSize="26" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0 5 0 0" HorizontalAlignment="Center"/>

                <TextBlock Text="Înregistrează-te pentru a începe"
                           FontSize="13" Foreground="{DynamicResource TextSecBrush}"
                           Margin="0 0 0 24" HorizontalAlignment="Center"/>

                <TextBlock Text="Email" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 0 0 4"/>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                    <TextBox x:Name="EmailTextBox"/>
                </Border>

                <TextBlock Text="Parolă" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 16 0 4"/>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                    <PasswordBox x:Name="PasswordBox"/>
                </Border>

                <Button x:Name="SignUpButton"
                        Content="Înregistrare"
                        Foreground="White"
                        Margin="0 20 0 10" Height="44" Cursor="Hand"
                        Click="SignUpButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#4285F4" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Grid Margin="0 4 0 10">
                    <Line X1="0" X2="1" Stretch="Fill"
                          Stroke="{DynamicResource DividerBrush}" StrokeThickness="1"/>
                    <TextBlock Text="sau"
                               Background="{DynamicResource CardBgBrush}"
                               Padding="10 0" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecBrush}" FontSize="12"/>
                </Grid>

                <Button x:Name="GoogleSignUpButton" Height="44" Cursor="Hand"
                        Click="GoogleSignUpButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1A1A1A"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Source="https://user-images.githubusercontent.com/194400/70987158-4069c900-20b7-11ea-892e-8a2e1166b6b7.png"
                                           Width="18" Height="18" Margin="0 0 10 0"/>
                                    <TextBlock Text="Continuă cu Google" Foreground="White"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock HorizontalAlignment="Center" Margin="0 18 0 10"
                           FontSize="12" Foreground="{DynamicResource TextSecBrush}">
                    <Hyperlink Click="LoginLink_Click" Foreground="#4285F4" TextDecorations="None">
                        Ai deja cont? Autentifică-te
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>