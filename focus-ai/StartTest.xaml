<Window x:Class="focus_ai.StartTest"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus AI – Test cognitiv"
        Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>

        <!-- Buton Start etapă -->
        <Style x:Key="StartStepBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentPrimary}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TxtMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buton ghost (Anulează) -->
        <Style x:Key="GhostBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TxtSecondary}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="18,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHover}"/>
                                <Setter Property="Foreground"                  Value="{DynamicResource TxtPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource BgRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border x:Name="HeaderBorder" Grid.Row="0"
                Background="{DynamicResource BgSidebar}"
                Padding="38,28,38,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="{DynamicResource AccentSecBg}"
                                CornerRadius="20" Padding="10,3">
                            <TextBlock Text="EVALUARE COGNITIVĂ" FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentSecFg}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TitleText"
                               Text="Test cognitiv"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}"
                               Margin="0,0,0,5"/>
                    <TextBlock x:Name="SubtitleText"
                               Text="Parcurge toate cele 3 etape în ordinea preferată. Cronometrul pornește la prima etapă lansată."
                               FontSize="13"
                               Foreground="{DynamicResource TxtSecondary}"/>
                </StackPanel>

                <!-- Cronometru global -->
                <Border x:Name="TimerBox" Grid.Column="1"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="14" Padding="26,14"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TIMP TOTAL" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TimerText"
                                   Text="00:00"
                                   FontSize="34" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentSecFg}"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TimerStatusText"
                                   Text="În așteptare"
                                   FontSize="10"
                                   Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Rectangle x:Name="SepLine" Grid.Row="0" VerticalAlignment="Bottom"
                   Height="1" Margin="38,0"
                   Fill="{DynamicResource BgSep}"/>

        <!-- ══ CARDS ══ -->
        <Grid Grid.Row="1" Margin="38,28,38,0"
              Background="{DynamicResource BgRoot}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1 — Urmărirea privirii -->
            <Border x:Name="Card1Border" Grid.Column="0"
                    Background="{DynamicResource BgCard}"
                    CornerRadius="18" Padding="24,24,24,22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="54" Height="54" CornerRadius="14"
                                Background="{DynamicResource AccentSecBg}"
                                HorizontalAlignment="Left">
                            <TextBlock Text="👁" FontSize="26"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="Status1Badge" Grid.Column="1"
                                CornerRadius="20" Padding="10,4" VerticalAlignment="Top"
                                Background="{DynamicResource BgCardHover}">
                            <TextBlock x:Name="Status1Text" Text="Neparcursă"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtSecondary}"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock x:Name="Card1Title" Text="Urmărirea privirii"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtPrimary}"
                                   Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock Text="Urmărește o țintă în mișcare cu privirea. Sistemul înregistrează traiectoria și precizia mișcărilor oculare."
                                   FontSize="12" Foreground="{DynamicResource TxtSecondary}"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </StackPanel>

                    <Button x:Name="StartBtn1" Grid.Row="2" Margin="0,20,0,0"
                            Style="{StaticResource StartStepBtnStyle}"
                            HorizontalAlignment="Stretch" Click="StartStep1_Click">
                        <TextBlock x:Name="StartBtn1Text" Text="▶  Start etapă"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Card 2 — Reacție la vibrație -->
            <Border x:Name="Card2Border" Grid.Column="2"
                    Background="{DynamicResource BgCard}"
                    CornerRadius="18" Padding="24,24,24,22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="54" Height="54" CornerRadius="14"
                                Background="{DynamicResource BgStatPurple}"
                                HorizontalAlignment="Left">
                            <TextBlock Text="📳" FontSize="26"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="Status2Badge" Grid.Column="1"
                                CornerRadius="20" Padding="10,4" VerticalAlignment="Top"
                                Background="{DynamicResource BgCardHover}">
                            <TextBlock x:Name="Status2Text" Text="Neparcursă"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtSecondary}"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock x:Name="Card2Title" Text="Reacție la vibrație"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtPrimary}"
                                   Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock Text="Răspunde cât mai rapid la impulsul haptic. Măsoară timpul de reacție la stimuli tactili pentru evaluarea reflexelor."
                                   FontSize="12" Foreground="{DynamicResource TxtSecondary}"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </StackPanel>

                    <Button x:Name="StartBtn2" Grid.Row="2" Margin="0,20,0,0"
                            Style="{StaticResource StartStepBtnStyle}"
                            HorizontalAlignment="Stretch" Click="StartStep2_Click">
                        <TextBlock x:Name="StartBtn2Text" Text="▶  Start etapă"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Card 3 — GO/NO-GO -->
            <Border x:Name="Card3Border" Grid.Column="4"
                    Background="{DynamicResource BgCard}"
                    CornerRadius="18" Padding="24,24,24,22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="54" Height="54" CornerRadius="14"
                                Background="{DynamicResource BgStatGreen}"
                                HorizontalAlignment="Left">
                            <TextBlock Text="🎯" FontSize="26"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="Status3Badge" Grid.Column="1"
                                CornerRadius="20" Padding="10,4" VerticalAlignment="Top"
                                Background="{DynamicResource BgCardHover}">
                            <TextBlock x:Name="Status3Text" Text="Neparcursă"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtSecondary}"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock x:Name="Card3Title" Text="Reacție vizuală GO/NO-GO"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtPrimary}"
                                   Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock Text="Răspunde la stimulii GO și inhibă reacția la stimulii NO-GO. Evaluează controlul inhibitor și viteza de procesare vizuală."
                                   FontSize="12" Foreground="{DynamicResource TxtSecondary}"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </StackPanel>

                    <Button x:Name="StartBtn3" Grid.Row="2" Margin="0,20,0,0"
                            Style="{StaticResource StartStepBtnStyle}"
                            HorizontalAlignment="Stretch" Click="StartStep3_Click">
                        <TextBlock x:Name="StartBtn3Text" Text="▶  Start etapă"/>
                    </Button>
                </Grid>
            </Border>

        </Grid>

        <!-- ══ FOOTER ══ -->
        <Border x:Name="FooterBorder" Grid.Row="2"
                Background="{DynamicResource BgSidebar}"
                Padding="38,16,38,26">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressText"
                               Text="0 / 3 etape finalizate"
                               FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                               VerticalAlignment="Center" Margin="0,0,24,0"/>
                    <Ellipse x:Name="ProgDot1" Width="10" Height="10"
                             Fill="{DynamicResource BgCardHover}" Margin="0,0,7,0"/>
                    <Ellipse x:Name="ProgDot2" Width="10" Height="10"
                             Fill="{DynamicResource BgCardHover}" Margin="0,0,7,0"/>
                    <Ellipse x:Name="ProgDot3" Width="10" Height="10"
                             Fill="{DynamicResource BgCardHover}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕  Anulează testul"
                        Style="{StaticResource GhostBtnStyle}"
                        Click="Cancel_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
