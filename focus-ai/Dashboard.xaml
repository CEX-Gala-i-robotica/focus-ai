<Window x:Class="focus_ai.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus AI - Dashboard" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Grid>
        <Border Background="White"
                Width="600"
                Height="300"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{Binding Source={x:Static SystemParameters.DropShadow}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Bun venit în Focus AI!"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#1A1A1A"
                           Margin="0,0,0,10"
                           TextAlignment="Center"/>
                <TextBlock Text="Aceasta este pagina principală a aplicației."
                           FontSize="16"
                           Foreground="#666"
                           Margin="0,0,0,30"
                           TextAlignment="Center"/>
                <Button x:Name="LogoutButton"
                        Content="Deconectare"
                        Height="40"
                        Width="150"
                        Background="#D32F2F"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LogoutButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>