<Window x:Class="focus_ai.TestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Test"
        Height="600" Width="700"
        Background="#0D0F14"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="SCATTER PLOT"
                   Foreground="#4DFFDF"
                   FontSize="11"
                   FontWeight="Bold"
                   Margin="0,0,0,12"
                   Opacity="0.7"/>

        <!-- Chart container -->
        <Border Grid.Row="1"
                BorderBrush="#1E2330"
                BorderThickness="1"
                CornerRadius="4"
                Padding="50,20,20,50">
            <Grid>
                <!-- Y axis labels -->
                <Canvas x:Name="YLabelsCanvas" Width="40" HorizontalAlignment="Left" Margin="-44,0,0,0"/>
                <!-- X axis labels -->
                <Canvas x:Name="XLabelsCanvas" Height="30" VerticalAlignment="Bottom" Margin="0,0,0,-34"/>
                <!-- Main graph -->
                <Canvas x:Name="GraphCanvas" Background="Transparent" ClipToBounds="True"/>
            </Grid>
        </Border>

        <!-- Stats bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <TextBlock x:Name="StatsText"
                       Foreground="#4A5568"
                       FontSize="11"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>