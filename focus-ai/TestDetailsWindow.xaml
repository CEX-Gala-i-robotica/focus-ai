<Window x:Class="focus_ai.TestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Test"
        Height="860" Width="820"
        Background="#0D0F14"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="*"/>      <!-- MAP scatter -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>      <!-- ECG -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>      <!-- SPO2 -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>      <!-- HR -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="55"/>     <!-- DIST -->
            <RowDefinition Height="Auto"/>   <!-- stats -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="DETALII TEST · GRAFICE EVOLUȚIE"
                   Foreground="#4DFFDF"
                   FontSize="11" FontWeight="Bold"
                   Margin="0,0,0,12" Opacity="0.7"/>

        <!-- ── MAP scatter ─────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="MAP  (scatter plot)"
                       Foreground="#4DFFDF" FontSize="9" Opacity="0.55"
                       Margin="0,0,0,4" FontFamily="Consolas"/>
            <Border Grid.Row="1" BorderBrush="#1E2330" BorderThickness="1"
                    CornerRadius="3" Padding="50,8,12,30">
                <Grid>
                    <Canvas x:Name="MapYLabels"  Width="40" HorizontalAlignment="Left" Margin="-44,0,0,0"/>
                    <Canvas x:Name="MapXLabels"  Height="22" VerticalAlignment="Bottom" Margin="0,0,0,-26"/>
                    <Canvas x:Name="MapCanvas"   Background="Transparent" ClipToBounds="True"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── ECG ─────────────────────────────────────────── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="ECG  (x1 – stânga · x2 – dreapta)"
                       Foreground="#4DFFDF" FontSize="9" Opacity="0.55"
                       Margin="0,0,0,4" FontFamily="Consolas"/>
            <Border Grid.Row="1" BorderBrush="#1E2330" BorderThickness="1"
                    CornerRadius="3" Padding="50,8,12,30">
                <Grid>
                    <Canvas x:Name="EcgYLabels"  Width="40" HorizontalAlignment="Left" Margin="-44,0,0,0"/>
                    <Canvas x:Name="EcgXLabels"  Height="22" VerticalAlignment="Bottom" Margin="0,0,0,-26"/>
                    <Canvas x:Name="EcgCanvas1"  Background="Transparent" ClipToBounds="True"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── SPO2 ────────────────────────────────────────── -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="SPO2  (%)"
                       Foreground="#4D9FFF" FontSize="9" Opacity="0.55"
                       Margin="0,0,0,4" FontFamily="Consolas"/>
            <Border Grid.Row="1" BorderBrush="#1E2330" BorderThickness="1"
                    CornerRadius="3" Padding="50,8,12,30">
                <Grid>
                    <Canvas x:Name="Spo2YLabels" Width="40" HorizontalAlignment="Left" Margin="-44,0,0,0"/>
                    <Canvas x:Name="Spo2XLabels" Height="22" VerticalAlignment="Bottom" Margin="0,0,0,-26"/>
                    <Canvas x:Name="Spo2Canvas"  Background="Transparent" ClipToBounds="True"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── HR ──────────────────────────────────────────── -->
        <Grid Grid.Row="7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="HR  (bpm)"
                       Foreground="#FF6B4D" FontSize="9" Opacity="0.55"
                       Margin="0,0,0,4" FontFamily="Consolas"/>
            <Border Grid.Row="1" BorderBrush="#1E2330" BorderThickness="1"
                    CornerRadius="3" Padding="50,8,12,30">
                <Grid>
                    <Canvas x:Name="HrYLabels"  Width="40" HorizontalAlignment="Left" Margin="-44,0,0,0"/>
                    <Canvas x:Name="HrXLabels"  Height="22" VerticalAlignment="Bottom" Margin="0,0,0,-26"/>
                    <Canvas x:Name="HrCanvas"   Background="Transparent" ClipToBounds="True"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── DIST ────────────────────────────────────────── -->
        <Grid Grid.Row="9">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="DIST  (momente active)"
                       Foreground="#A0A0FF" FontSize="9" Opacity="0.55"
                       Margin="0,0,0,4" FontFamily="Consolas"/>
            <Border Grid.Row="1" BorderBrush="#1E2330" BorderThickness="1"
                    CornerRadius="3" Padding="50,4,12,4">
                <Canvas x:Name="DistCanvas" Background="Transparent" ClipToBounds="True"/>
            </Border>
        </Grid>

        <!-- ── Stats bar ────────────────────────────────────── -->
        <TextBlock x:Name="StatsText" Grid.Row="10"
                   Foreground="#4A5568" FontSize="10" FontFamily="Consolas"
                   Margin="0,10,0,0" VerticalAlignment="Center"/>
    </Grid>
</Window>
