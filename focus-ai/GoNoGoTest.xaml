<Window x:Class="focus_ai.GoNoGoTest"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:focus_ai"
        mc:Ignorable="d"
        Title="Focus AI – GO/NO-GO"
        Height="800" Width="1200"
        WindowState="Maximized"
        ResizeMode="CanMinimize">

    <Window.Resources>

        <!-- Pulse ring animation -->
        <Storyboard x:Key="PulseAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="2.2" Duration="0:0:1.0"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="2.2" Duration="0:0:1.0"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing1"
                             Storyboard.TargetProperty="Opacity"
                             From="0.6" To="0" Duration="0:0:1.0"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="2.2" Duration="0:0:1.0" BeginTime="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="2.2" Duration="0:0:1.0" BeginTime="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing2"
                             Storyboard.TargetProperty="Opacity"
                             From="0.6" To="0" Duration="0:0:1.0" BeginTime="0:0:0.4"/>
        </Storyboard>

    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource BgRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Footer / bio strip -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource BgSidebar}"
                Padding="40,22,40,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="{DynamicResource BgStatGreen}"
                                CornerRadius="20" Padding="10,3">
                            <TextBlock Text="GO / NO-GO" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtPrimary}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Test de inhibiție vizuală"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}"/>
                    <TextBlock x:Name="InstructionText"
                               Text="Apasă senzorul DOAR când ecranul este VERDE. Ignoră stimulii ROȘII."
                               FontSize="12" Foreground="{DynamicResource TxtSecondary}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Timer box -->
                <Border Grid.Column="1" Background="{DynamicResource BgCard}"
                        CornerRadius="14" Padding="24,12" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TIMP RĂMAS" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,3"/>
                        <TextBlock x:Name="CountdownText"
                                   Text="30"
                                   FontSize="38" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentSecFg}"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TimerStatusText"
                                   Text="În așteptare"
                                   FontSize="10" Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ MAIN STIMULUS AREA ═══════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Stimulus circle (fills most of the area) -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Pulse rings (shown only during GO) -->
                <Ellipse x:Name="PulseRing1"
                         Width="260" Height="260"
                         Opacity="0" IsHitTestVisible="False">
                    <Ellipse.RenderTransform>
                        <ScaleTransform CenterX="130" CenterY="130"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Fill>
                        <SolidColorBrush x:Name="PulseRing1Brush" Color="#2222C55E"/>
                    </Ellipse.Fill>
                </Ellipse>

                <Ellipse x:Name="PulseRing2"
                         Width="260" Height="260"
                         Opacity="0" IsHitTestVisible="False">
                    <Ellipse.RenderTransform>
                        <ScaleTransform CenterX="130" CenterY="130"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Fill>
                        <SolidColorBrush x:Name="PulseRing2Brush" Color="#2222C55E"/>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Main stimulus ellipse -->
                <Ellipse x:Name="StimulusCircle"
                         Width="260" Height="260">
                    <Ellipse.Fill>
                        <SolidColorBrush x:Name="CircleBrush" Color="#1F2937"/>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Label inside circle -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="StimulusLabel"
                               Text="—"
                               FontSize="52" FontWeight="Black"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="White"/>
                    <TextBlock x:Name="StimulusSubLabel"
                               Text=""
                               FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="#99FFFFFF"
                               Margin="0,4,0,0"/>
                </StackPanel>

            </Grid>

            <!-- Overlay: waiting / finished message -->
            <Border x:Name="OverlayPanel"
                    Background="{DynamicResource BgRoot}"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            MaxWidth="480">
                    <TextBlock x:Name="OverlayTitle"
                               Text="Pregătit pentru testul GO/NO-GO?"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <TextBlock x:Name="OverlayBody"
                               Text="Testul durează 30 de secunde. Apasă senzorul NUMAI când apare culoarea VERDE (GO). Ignoră culoarea ROȘIE (NO-GO). Reacțiile false sunt penalizate."
                               FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,14,0,32"
                               LineHeight="21"/>

                    <Button x:Name="BeginButton"
                            Content="▶  Începe testul"
                            HorizontalAlignment="Center"
                            Padding="32,14"
                            FontSize="14" FontWeight="SemiBold"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BeginButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource AccentPrimary}"
                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>

        <!-- ══ FOOTER — BIO METRICS STRIP ══════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource BgSidebar}"
                Padding="40,14,40,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Correct GO -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="✅  GO CORECTE" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TxtMuted}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CorrectGoText" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}" HorizontalAlignment="Center"
                               FontFamily="Consolas"/>
                </StackPanel>

                <!-- False positives -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="❌  FALSE POZITIVE" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TxtMuted}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="FalsePosText" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#EF4444" HorizontalAlignment="Center"
                               FontFamily="Consolas"/>
                </StackPanel>

                <!-- Avg reaction time -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="⚡  TIMP MEDIU" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TxtMuted}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="AvgRtText" Text="-- ms"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}" HorizontalAlignment="Center"
                               FontFamily="Consolas"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Window>