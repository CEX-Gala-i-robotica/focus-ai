<Window x:Class="focus_ai.GameSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alege un joc" Height="500" Width="750"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <!-- Stil card joc (identic cu cel din Dashboard) -->
        <Style x:Key="GameCardStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder" Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="20">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background"
                                        Value="{DynamicResource BgCardHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Culori pentru fundalurile iconițelor jocurilor -->
        <SolidColorBrush x:Key="GameCard1Bg" Color="#3B82F6" Opacity="0.15"/>
        <SolidColorBrush x:Key="GameCard2Bg" Color="#8B5CF6" Opacity="0.15"/>
        <SolidColorBrush x:Key="GameCard3Bg" Color="#10B981" Opacity="0.15"/>
        <SolidColorBrush x:Key="GameCard4Bg" Color="#F59E0B" Opacity="0.15"/>
        <SolidColorBrush x:Key="GameCard5Bg" Color="#EF4444" Opacity="0.15"/>
    </Window.Resources>

    <Grid Background="{DynamicResource BgRoot}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                <TextBlock Text="Selectează un joc de antrenament cognitiv"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TxtPrimary}"
                           Margin="0,0,0,20"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Rând 1 -->
                    <Button Grid.Column="0" Grid.Row="0" Style="{StaticResource GameCardStyle}"
                            Click="GameMemorie_Click">
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="14"
                                    Background="{DynamicResource GameCard1Bg}"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <TextBlock Text="🧠" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Memorie" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtPrimary}" Margin="0,0,0,6"/>
                            <TextBlock Text="Antrenează memoria de scurtă durată cu perechi de carduri."
                                       FontSize="11" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Grid.Row="0" Style="{StaticResource GameCardStyle}"
                            Click="GameStroop_Click">
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="14"
                                    Background="{DynamicResource GameCard2Bg}"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <TextBlock Text="🎨" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Stroop Test" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtPrimary}" Margin="0,0,0,6"/>
                            <TextBlock Text="Identifică culoarea cuvântului, ignorând semnificația sa."
                                       FontSize="11" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Grid.Row="0" Style="{StaticResource GameCardStyle}"
                            Click="GameVisualSearch_Click">
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="14"
                                    Background="{DynamicResource GameCard3Bg}"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <TextBlock Text="🔍" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Visual Search" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtPrimary}" Margin="0,0,0,6"/>
                            <TextBlock Text="Găsește elementul diferit ascuns printre multe elemente similare."
                                       FontSize="11" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Button>

                    <!-- Rând 2 -->
                    <Button Grid.Column="0" Grid.Row="2" Style="{StaticResource GameCardStyle}"
                            Click="GameSecvente_Click">
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="14"
                                    Background="{DynamicResource GameCard4Bg}"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <TextBlock Text="🔢" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Secvențe" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtPrimary}" Margin="0,0,0,6"/>
                            <TextBlock Text="Memorează și reproduce secvențe din ce în ce mai lungi."
                                       FontSize="11" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Grid.Row="2" Style="{StaticResource GameCardStyle}"
                            Click="GameMatematica_Click">
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="14"
                                    Background="{DynamicResource GameCard5Bg}"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <TextBlock Text="➕" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Matematică rapidă" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtPrimary}" Margin="0,0,0,6"/>
                            <TextBlock Text="Rezolvă operații matematice cât mai repede posibil."
                                       FontSize="11" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>