<Window x:Class="focus_ai.VisualSearchGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus AI - Visual Search"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid x:Name="RootGrid" Background="{DynamicResource BgRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="{DynamicResource BgSidebar}"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnBack" Content="← Înapoi"
                            Background="Transparent" Foreground="{DynamicResource TxtSecondary}"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="BtnBack_Click" Margin="0,0,20,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Visual Search" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource TxtPrimary}"/>
                        <TextBlock x:Name="TxtDifficulty" Text="Dificil"
                                   FontSize="11" Foreground="{DynamicResource TxtSecondary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Stats bar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <Border Background="{DynamicResource BgStatBlue}"
                            CornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="NIVEL" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatBlue}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtLevel" Text="1"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BgStatGreen}"
                            CornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="SCOR" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatGreen}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtScore" Text="0"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BgStatOrange}"
                            CornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="VIEȚI" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatOrange}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtLives" Text="❤️❤️❤️"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BgStatPurple}"
                            CornerRadius="10" Padding="14,8">
                        <StackPanel>
                            <TextBlock Text="TIMP" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatPurple}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtTimer" Text="30"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── GAME AREA ── -->
        <Border Grid.Row="1" Background="{DynamicResource BgMain}" Padding="24,20">
            <Grid>
                <!-- Instruction -->
                <Border x:Name="PanelInstruction"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="20" Padding="40">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="52"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Visual Search"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource TxtPrimary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Găsește elementul DIFERIT ascuns printre cele similare."
                                   FontSize="14" Foreground="{DynamicResource TxtSecondary}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="420" Margin="0,0,0,6"/>
                        <TextBlock Text="Cu cât avansezi, cu atât grila devine mai mare și mai greu de scanat."
                                   FontSize="12" Foreground="{DynamicResource TxtSecondary}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="420" Margin="0,0,0,30"/>

                        <!-- Difficulty selector -->
                        <TextBlock Text="DIFICULTATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,0,0,30">
                            <RadioButton x:Name="RbEasy" Content="Ușor"
                                         GroupName="Diff" Margin="0,0,16,0"
                                         Foreground="{DynamicResource TxtPrimary}"
                                         FontSize="13" Cursor="Hand"/>
                            <RadioButton x:Name="RbMedium" Content="Mediu"
                                         GroupName="Diff" IsChecked="True"
                                         Margin="0,0,16,0"
                                         Foreground="{DynamicResource TxtPrimary}"
                                         FontSize="13" Cursor="Hand"/>
                            <RadioButton x:Name="RbHard" Content="Dificil"
                                         GroupName="Diff"
                                         Foreground="{DynamicResource TxtPrimary}"
                                         FontSize="13" Cursor="Hand"/>
                        </StackPanel>

                        <Button x:Name="BtnStart" Content="▶  Începe jocul"
                                Background="{DynamicResource AccentPrimary}"
                                Foreground="White" FontSize="15" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Padding="32,14" Click="BtnStart_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource AccentHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Playing -->
                <Grid x:Name="PanelGame" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Instruction bar -->
                    <Border Grid.Row="0" Background="{DynamicResource BgCard}"
                            CornerRadius="12" Padding="18,12" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Caută: " FontSize="13"
                                       Foreground="{DynamicResource TxtSecondary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTarget" Text=""
                                       FontSize="22" VerticalAlignment="Center"
                                       Margin="6,0,16,0"/>
                            <TextBlock x:Name="TxtInstructionDetail"
                                       Text="— Găsește elementul diferit!"
                                       FontSize="13"
                                       Foreground="{DynamicResource TxtSecondary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <UniformGrid x:Name="GameGrid"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"/>
                    </ScrollViewer>
                </Grid>

                <!-- Feedback overlay -->
                <Border x:Name="PanelFeedback" Visibility="Collapsed"
                        Background="#AA000000" CornerRadius="16">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtFeedbackIcon" Text="✅"
                                   FontSize="60" HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock x:Name="TxtFeedbackMsg" Text=""
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtFeedbackSub" Text=""
                                   FontSize="14" Foreground="#BBBBBB"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Game Over -->
                <Border x:Name="PanelGameOver" Visibility="Collapsed"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="20" Padding="40">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtGameOverIcon" Text="💀"
                                   FontSize="52" HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock x:Name="TxtGameOverTitle" Text="Game Over"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource TxtPrimary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtGameOverSub" Text=""
                                   FontSize="14" Foreground="{DynamicResource TxtSecondary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,30"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="380"/>

                        <!-- Score card -->
                        <Border Background="{DynamicResource BgStatBlue}"
                                CornerRadius="14" Padding="30,20" Margin="0,0,0,30">
                            <StackPanel>
                                <TextBlock Text="SCOR FINAL" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtStatBlue}"
                                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtFinalScore" Text="0"
                                           FontSize="42" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtFinalDetails" Text=""
                                           FontSize="12" Foreground="{DynamicResource TxtSecondary}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnRestart" Content="🔄  Joacă din nou"
                                    Background="{DynamicResource AccentPrimary}"
                                    Foreground="White" FontSize="14" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand"
                                    Padding="24,12" Margin="0,0,12,0"
                                    Click="BtnRestart_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AccentHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnGoBack" Content="← Dashboard"
                                    Background="{DynamicResource AccentSecBg}"
                                    Foreground="{DynamicResource AccentSecFg}"
                                    FontSize="14" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand"
                                    Padding="24,12"
                                    Click="BtnBack_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AccentSecHov}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── PROGRESS BAR ── -->
        <Border Grid.Row="2" Background="{DynamicResource BgSidebar}" Padding="28,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource BgCard}"
                        CornerRadius="4" Height="6" VerticalAlignment="Center">
                    <Border x:Name="TimerBar" Background="{DynamicResource AccentPrimary}"
                            CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                </Border>
                <TextBlock Grid.Column="1" x:Name="TxtRoundInfo"
                           Text="Nivel 1" FontSize="11"
                           Foreground="{DynamicResource TxtMuted}"
                           Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>