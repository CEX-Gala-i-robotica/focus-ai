<Window x:Class="focus_ai.VisualSearchGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus AI - Visual Search"
        WindowState="Maximized"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">
    <Grid x:Name="RootGrid" Background="{DynamicResource BgRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgSidebar}" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnBack"
                            Content="← Înapoi"
                            FontSize="13" FontWeight="SemiBold"
                            Background="{DynamicResource AccentSecBg}"
                            Foreground="{DynamicResource AccentSecFg}"
                            BorderThickness="0" Cursor="Hand"
                            Padding="14,8"
                            Click="BtnBack_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource AccentSecHov}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Visual Search" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource TxtPrimary}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource BgStatBlue}" CornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="RUNDA" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatBlue}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtRound" Text="0/8" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BgStatGreen}" CornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="SCOR" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatGreen}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtScore" Text="0" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BgStatOrange}" CornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="VIEȚI" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatOrange}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtLives" Text="❤️❤️❤️" FontSize="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BgStatPurple}" CornerRadius="10" Padding="14,8">
                        <StackPanel>
                            <TextBlock Text="TIMP" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatPurple}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtTimer" Text="20" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" Background="{DynamicResource BgMain}" Padding="20,16">
            <Grid>
                <!-- PANEL INSTRUCȚIUNI -->
                <Border x:Name="PanelInstruction" Background="{DynamicResource BgCard}" CornerRadius="20" Padding="40">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
                        <TextBlock Text="🔍" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Find The Odd One" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TxtPrimary}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock FontSize="14" Foreground="{DynamicResource TxtSecondary}" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400" Margin="0,0,0,28" LineHeight="22">
                            Grila e plină cu un singur caracter repetat.&#x0a;
                            Undeva e ascuns unul diferit — găsește-l înainte să expire timpul!&#x0a;
                            Cu fiecare rundă, grila devine mai mare.
                        </TextBlock>

                        <Border Background="{DynamicResource BgNavHover}" CornerRadius="12" Padding="20,14" Margin="0,0,0,28">
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TxtMuted}"
                                           HorizontalAlignment="Center" Margin="0,0,0,10" Text="PREVIEW"/>
                                <TextBlock FontSize="20" FontWeight="Bold" FontFamily="Consolas, Courier New"
                                           Foreground="{DynamicResource TxtPrimary}" HorizontalAlignment="Center" TextAlignment="Center"
                                           Text="S S S S S S S S S S&#x0a;S S S S 5 S S S S S&#x0a;S S S S S S S S S S"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="8 runde  •  3 vieți" FontSize="13" Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,24"/>

                        <TextBlock Text="DIFICULTATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                            <RadioButton x:Name="RbEasy" Content="Ușor  (25s)" GroupName="Diff" Margin="0,0,16,0"
                                         Foreground="{DynamicResource TxtPrimary}" FontSize="13" Cursor="Hand"/>
                            <RadioButton x:Name="RbMedium" Content="Mediu  (20s)" GroupName="Diff" IsChecked="True" Margin="0,0,16,0"
                                         Foreground="{DynamicResource TxtPrimary}" FontSize="13" Cursor="Hand"/>
                            <RadioButton x:Name="RbHard" Content="Dificil  (15s)" GroupName="Diff"
                                         Foreground="{DynamicResource TxtPrimary}" FontSize="13" Cursor="Hand"/>
                        </StackPanel>

                        <Button x:Name="BtnStart" Content="▶  Începe jocul" Background="{DynamicResource AccentPrimary}"
                                Foreground="White" FontSize="15" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Padding="32,14" Click="BtnStart_Click" HorizontalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- PANEL JOC -->
                <Grid x:Name="PanelGame" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <UniformGrid x:Name="GameGrid" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,8"/>
                    </ScrollViewer>

                    <!-- Feedback temporar (corectat) -->
                    <Border x:Name="PanelFeedback" Visibility="Collapsed"
                            Background="#CC000000" CornerRadius="24"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Padding="32,24">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtFeedbackIcon" Text="✅" FontSize="48"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock x:Name="TxtFeedbackMsg" Text="" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtFeedbackSub" Text="" FontSize="13"
                                       Foreground="#DDDDDD" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer / Timer Bar -->
        <Border Grid.Row="2" Background="{DynamicResource BgSidebar}" Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="4" Height="6" VerticalAlignment="Center">
                    <Border x:Name="TimerBar" CornerRadius="4" Background="{DynamicResource AccentPrimary}"
                            HorizontalAlignment="Left" Width="0"/>
                </Border>
                <TextBlock Grid.Column="1" x:Name="TxtRoundInfo" Text="Runda 1/8" FontSize="11"
                           Foreground="{DynamicResource TxtMuted}" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- OVERLAY DE FINAL – corectat pentru a acoperi întreaga fereastră -->
        <Border Grid.Row="0" Grid.RowSpan="3" x:Name="WinOverlay" Visibility="Collapsed"
                Background="#CC000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource BgCard}" CornerRadius="24"
                    Padding="32,28" MinWidth="360" MaxWidth="420">
                <StackPanel>
                    <TextBlock x:Name="WinEmoji" Text="🏆" FontSize="64"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock x:Name="WinTitle" Text="Felicitări!" FontSize="26"
                               FontWeight="Bold" Foreground="{DynamicResource TxtPrimary}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="WinSubtitle" Text=""
                               FontSize="14" Foreground="{DynamicResource TxtSecondary}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock x:Name="WinScore" Text="Scor: 0"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource AccentPrimary}"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>
                    <Button Content="🔄  Joacă din nou"
                            Click="BtnRestart_Click"
                            Background="{DynamicResource AccentPrimary}"
                            Foreground="White" FontSize="14" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Padding="20,10" HorizontalAlignment="Center"
                            Margin="0,0,0,12" MinWidth="180">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="12" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource AccentHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="← Înapoi la meniu"
                            Click="BtnHome_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource AccentPrimary}"
                            FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Padding="20,10" HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="12" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource BgNavHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>