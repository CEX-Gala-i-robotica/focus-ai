<Window x:Class="focus_ai.StroopGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus AI – Stroop Test" Height="660" Width="860"
        WindowState="Maximized"
        ResizeMode="CanMinimize">

    <Grid x:Name="RootGrid" Background="{DynamicResource BgRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BgSidebar}" Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton"
                        Grid.Column="0"
                        Content="← Înapoi"
                        FontSize="13" FontWeight="SemiBold"
                        Background="{DynamicResource AccentSecBg}"
                        Foreground="{DynamicResource AccentSecFg}"
                        BorderThickness="0" Cursor="Hand"
                        Padding="14,8"
                        Click="BackButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource AccentSecHov}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="🎨  Stroop Test"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Culoarea contează, nu cuvântul!"
                               FontSize="12"
                               Foreground="{DynamicResource TxtSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="2" Width="80"/>
            </Grid>
        </Border>

        <!-- CONTINUT PRINCIPAL -->
        <Grid Grid.Row="1">
            <!-- SCREEN: INTRO -->
            <Border x:Name="ScreenIntro" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            MaxWidth="520">
                    <Border Width="90" Height="90" CornerRadius="22"
                            Background="{DynamicResource GameCard2Bg}"
                            HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="🎨" FontSize="44"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Stroop Test" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock TextAlignment="Center" FontSize="14"
                               Foreground="{DynamicResource TxtSecondary}"
                               TextWrapping="Wrap" Margin="0,0,0,32"
                               LineHeight="22">
                        Identifică <Bold><Italic> culoarea </Italic></Bold> în care este scris cuvântul,
                        ignorând semnificația acestuia.&#x0a;
                        Răspunde cât mai repede și mai corect posibil!
                    </TextBlock>

                    <Border Background="{DynamicResource BgCard}" CornerRadius="16"
                            Padding="24,20" Margin="0,0,0,32">
                        <StackPanel>
                            <TextBlock Text="CUM SE JOACĂ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtMuted}" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                        Background="{DynamicResource BgStatBlue}" VerticalAlignment="Top">
                                    <TextBlock Text="1" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TxtStatBlue}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Apare un cuvânt colorat pe ecran."
                                           FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                        Background="{DynamicResource BgStatGreen}" VerticalAlignment="Top">
                                    <TextBlock Text="2" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TxtStatGreen}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Apasă butonul cu culoarea cuvântului, nu cu semnificația lui!"
                                           FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                        Background="{DynamicResource BgStatPurple}" VerticalAlignment="Top">
                                    <TextBlock Text="3" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TxtStatPurple}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Ai 30 de întrebări. Fiecare răspuns corect îți aduce puncte; viteza contează!"
                                           FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DIFICULTATE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TxtMuted}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                        <RadioButton x:Name="DiffEasy" Content="Ușor" GroupName="Diff"
                                     IsChecked="True" FontSize="13" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TxtPrimary}"
                                     Cursor="Hand" Margin="0,0,16,0"/>
                        <RadioButton x:Name="DiffMedium" Content="Mediu" GroupName="Diff"
                                     FontSize="13" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TxtPrimary}"
                                     Cursor="Hand" Margin="0,0,16,0"/>
                        <RadioButton x:Name="DiffHard" Content="Dificil" GroupName="Diff"
                                     FontSize="13" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TxtPrimary}"
                                     Cursor="Hand"/>
                    </StackPanel>

                    <Button x:Name="BtnStart" Content="🚀  Începe jocul"
                            Click="BtnStart_Click"
                            Background="{DynamicResource AccentPrimary}"
                            Foreground="White" FontSize="15" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Center" Padding="40,14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- SCREEN: GAME -->
            <Border x:Name="ScreenGame" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Bară statistici -->
                    <Border Grid.Row="0" Background="{DynamicResource BgSidebar}"
                            Padding="24,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <Grid Margin="0,0,0,5">
                                    <TextBlock x:Name="TxtProgress"
                                               Text="Runda 1 / 30"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TxtMuted}"/>
                                    <TextBlock x:Name="TxtDifficulty"
                                               Text="Ușor"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TxtMuted}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="6" CornerRadius="3"
                                        Background="{DynamicResource BgNavHover}">
                                    <Border x:Name="ProgressBar" Height="6" CornerRadius="3"
                                            Background="{DynamicResource AccentPrimary}"
                                            HorizontalAlignment="Left" Width="0"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTimer" Text="∞"
                                           FontSize="30" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="sec" FontSize="9"
                                           Foreground="{DynamicResource TxtMuted}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <TextBlock Text="SCOR" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtMuted}"
                                           HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                <TextBlock x:Name="TxtScore" Text="0"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Zona centrală -->
                    <Grid Grid.Row="1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border x:Name="StreakBadge" Background="{DynamicResource BgStatOrange}"
                                    CornerRadius="20" Padding="14,6"
                                    HorizontalAlignment="Center" Margin="0,0,0,20"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="TxtStreak" Text="🔥 3 la rând!"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtStatOrange}"/>
                            </Border>

                            <TextBlock x:Name="WordLabel" Text="ROȘU"
                                       FontSize="72" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,50"/>

                            <Grid x:Name="ButtonGrid" Width="500">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button x:Name="Btn0" Grid.Column="0" Grid.Row="0"
                                        Height="60" FontSize="16" FontWeight="Bold"
                                        BorderThickness="2" Cursor="Hand" Click="Answer_Click" Tag="0"/>
                                <Button x:Name="Btn1" Grid.Column="2" Grid.Row="0"
                                        Height="60" FontSize="16" FontWeight="Bold"
                                        BorderThickness="2" Cursor="Hand" Click="Answer_Click" Tag="1"/>
                                <Button x:Name="Btn2" Grid.Column="0" Grid.Row="2"
                                        Height="60" FontSize="16" FontWeight="Bold"
                                        BorderThickness="2" Cursor="Hand" Click="Answer_Click" Tag="2"/>
                                <Button x:Name="Btn3" Grid.Column="2" Grid.Row="2"
                                        Height="60" FontSize="16" FontWeight="Bold"
                                        BorderThickness="2" Cursor="Hand" Click="Answer_Click" Tag="3"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Bară jos -->
                    <Border Grid.Row="2" Background="{DynamicResource BgSidebar}" Padding="28,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="✅ " FontSize="14"/>
                                <TextBlock x:Name="TxtCorrect" Text="0 corecte"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#22C55E" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="❌ " FontSize="14"/>
                                <TextBlock x:Name="TxtWrong" Text="0 greșite"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#EF4444" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- SCREEN: RESULTS (păstrat pentru compatibilitate) -->
            <Border x:Name="ScreenResults" Visibility="Collapsed"/>
        </Grid>

        <!-- OVERLAY DE FINAL – acoperă întreaga fereastră -->
        <Grid Grid.Row="0" Grid.RowSpan="2" x:Name="WinOverlay" Visibility="Collapsed" Background="#CC000000">
            <Border CornerRadius="24" Padding="48,40" Background="{DynamicResource BgCard}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="360">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="WinEmoji" Text="🏆" FontSize="52"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="WinTitle" Text="Excelent!" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock x:Name="WinSubtitle" Text=""
                               FontSize="14" Foreground="{DynamicResource TxtSecondary}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock x:Name="WinScore" Text="Scor final: 0 / 100"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentSecFg}"
                               HorizontalAlignment="Center" Margin="0,0,0,24" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="🔄  Joacă din nou"
                                Click="WinPlayAgain_Click"
                                Background="{DynamicResource AccentPrimary}"
                                Foreground="White" FontSize="13" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="9" Padding="20,10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="← Înapoi la meniu"
                                Click="BackButton_Click"
                                Background="{DynamicResource AccentSecBg}"
                                Foreground="{DynamicResource AccentSecFg}"
                                FontSize="13" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="9" Padding="20,10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentSecHov}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>