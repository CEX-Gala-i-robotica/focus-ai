<Window x:Class="focus_ai.StroopGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus AI – Stroop Test" Height="660" Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid x:Name="RootGrid" Background="{DynamicResource BgRoot}">

        <!-- ══ SCREEN: INTRO ══ -->
        <Border x:Name="ScreenIntro" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="520">

                <!-- Icon -->
                <Border Width="90" Height="90" CornerRadius="22"
                        Background="{DynamicResource GameCard2Bg}"
                        HorizontalAlignment="Center" Margin="0,0,0,24">
                    <TextBlock Text="🎨" FontSize="44"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Stroop Test" FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource TxtPrimary}"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock TextAlignment="Center" FontSize="14"
                           Foreground="{DynamicResource TxtSecondary}"
                           TextWrapping="Wrap" Margin="0,0,0,32"
                           LineHeight="22">
                    Identifică <Bold><Italic>culoarea</Italic></Bold> în care este scris cuvântul,
                    ignorând semnificația acestuia.&#x0a;
                    Răspunde cât mai repede și mai corect posibil!
                </TextBlock>

                <!-- Rules card -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="16"
                        Padding="24,20" Margin="0,0,0,32">
                    <StackPanel>
                        <TextBlock Text="CUM SE JOACĂ" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtMuted}" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                    Background="{DynamicResource BgStatBlue}"
                                    VerticalAlignment="Top">
                                <TextBlock Text="1" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtStatBlue}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Apare un cuvânt colorat pe ecran."
                                       FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                    Background="{DynamicResource BgStatGreen}"
                                    VerticalAlignment="Top">
                                <TextBlock Text="2" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtStatGreen}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Apasă butonul cu culoarea CERNEALĂ-ului, nu cu semnificația cuvântului!"
                                       FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                    Background="{DynamicResource BgStatPurple}"
                                    VerticalAlignment="Top">
                                <TextBlock Text="3" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtStatPurple}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Ai 30 de întrebări. Fiecare răspuns corect îți aduce puncte; viteza contează!"
                                       FontSize="13" Foreground="{DynamicResource TxtSecondary}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Difficulty -->
                <TextBlock Text="DIFICULTATE" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TxtMuted}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                    <RadioButton x:Name="DiffEasy" Content="Ușor" GroupName="Diff"
                                 IsChecked="True"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TxtPrimary}"
                                 Cursor="Hand" Margin="0,0,16,0"/>
                    <RadioButton x:Name="DiffMedium" Content="Mediu" GroupName="Diff"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TxtPrimary}"
                                 Cursor="Hand" Margin="0,0,16,0"/>
                    <RadioButton x:Name="DiffHard" Content="Dificil" GroupName="Diff"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TxtPrimary}"
                                 Cursor="Hand"/>
                </StackPanel>

                <Button x:Name="BtnStart" Content="🚀  Începe jocul"
                        Click="BtnStart_Click"
                        Background="{DynamicResource AccentPrimary}"
                        Foreground="White" FontSize="15" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Center" Padding="40,14">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="← Înapoi la Dashboard"
                        Click="BtnBack_Click"
                        Background="Transparent" Foreground="{DynamicResource TxtSecondary}"
                        FontSize="12" BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,14,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- ══ SCREEN: GAME ══ -->
        <Border x:Name="ScreenGame" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top bar -->
                <Border Grid.Row="0" Background="{DynamicResource BgSidebar}"
                        Padding="28,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Progress -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtProgress" Text="Întrebarea 1 / 30"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtMuted}" Margin="0,0,0,6"/>
                            <Border Height="6" CornerRadius="3"
                                    Background="{DynamicResource BgNavHover}">
                                <Border x:Name="ProgressBar" Height="6" CornerRadius="3"
                                        Background="{DynamicResource AccentPrimary}"
                                        HorizontalAlignment="Left" Width="0"/>
                            </Border>
                        </StackPanel>

                        <!-- Timer -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtTimer" Text="00.0"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="secunde" FontSize="10"
                                       Foreground="{DynamicResource TxtMuted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Score -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="SCOR" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtMuted}"
                                       HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtScore" Text="0"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource TxtPrimary}"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Center: word + feedback -->
                <Grid Grid.Row="1">

                    <!-- Feedback flash overlay -->
                    <Border x:Name="FeedbackOverlay" CornerRadius="0"
                            Background="Transparent" IsHitTestVisible="False">
                        <TextBlock x:Name="FeedbackIcon" Text="" FontSize="60"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <!-- Streak badge -->
                        <Border x:Name="StreakBadge" Background="{DynamicResource BgStatOrange}"
                                CornerRadius="20" Padding="14,6"
                                HorizontalAlignment="Center" Margin="0,0,0,20"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TxtStreak" Text="🔥 3 la rând!"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtStatOrange}"/>
                        </Border>

                        <!-- The word -->
                        <TextBlock x:Name="WordLabel" Text="ROȘU"
                                   FontSize="72" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,50"/>

                        <!-- Answer buttons 2x2 -->
                        <Grid x:Name="ButtonGrid" Width="500">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Btn 0 -->
                            <Button x:Name="Btn0" Grid.Column="0" Grid.Row="0"
                                    Height="60" FontSize="16" FontWeight="Bold"
                                    BorderThickness="2" Cursor="Hand"
                                    Click="Answer_Click" Tag="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="BtnBd" Property="Opacity" Value="0.65"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Btn 1 -->
                            <Button x:Name="Btn1" Grid.Column="2" Grid.Row="0"
                                    Height="60" FontSize="16" FontWeight="Bold"
                                    BorderThickness="2" Cursor="Hand"
                                    Click="Answer_Click" Tag="1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Btn 2 -->
                            <Button x:Name="Btn2" Grid.Column="0" Grid.Row="2"
                                    Height="60" FontSize="16" FontWeight="Bold"
                                    BorderThickness="2" Cursor="Hand"
                                    Click="Answer_Click" Tag="2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Btn 3 -->
                            <Button x:Name="Btn3" Grid.Column="2" Grid.Row="2"
                                    Height="60" FontSize="16" FontWeight="Bold"
                                    BorderThickness="2" Cursor="Hand"
                                    Click="Answer_Click" Tag="3">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Bottom: correct/wrong counters -->
                <Border Grid.Row="2" Background="{DynamicResource BgSidebar}" Padding="28,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="✅ " FontSize="14"/>
                            <TextBlock x:Name="TxtCorrect" Text="0 corecte"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#22C55E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="TxtDifficulty"
                                   Text="Ușor" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="❌ " FontSize="14"/>
                            <TextBlock x:Name="TxtWrong" Text="0 greșite"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#EF4444" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══ SCREEN: RESULTS ══ -->
        <Border x:Name="ScreenResults" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            MaxWidth="560" Margin="0,40,0,40">

                    <!-- Trophy or medal -->
                    <TextBlock x:Name="TrophyIcon" Text="🏆"
                               FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <TextBlock x:Name="ResultTitle" Text="Joc terminat!"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TxtPrimary}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>

                    <TextBlock x:Name="ResultSubtitle" Text="Felicitări pentru concentrare!"
                               FontSize="14" Foreground="{DynamicResource TxtSecondary}"
                               HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Score big -->
                    <Border Background="{DynamicResource BgCard}" CornerRadius="20"
                            Padding="32,28" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="SCOR FINAL" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TxtMuted}"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock x:Name="BigScore" Text="0.00"
                                       FontSize="64" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentPrimary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="/ 100" FontSize="14"
                                       Foreground="{DynamicResource TxtMuted}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Stats grid -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Column="0" Grid.Row="0" Background="{DynamicResource BgStatGreen}"
                                CornerRadius="14" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="✅  CORECTE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtStatGreen}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="ResCorrect" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Grid.Row="0" Background="{DynamicResource BgStatPurple}"
                                CornerRadius="14" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="❌  GREȘITE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtStatPurple}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="ResWrong" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="0" Grid.Row="2" Background="{DynamicResource BgStatBlue}"
                                CornerRadius="14" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="⚡  TIMP MEDIU / RĂSPUNS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtStatBlue}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="ResAvgTime" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Grid.Row="2" Background="{DynamicResource BgStatOrange}"
                                CornerRadius="14" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="🔥  STREAK MAX" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtStatOrange}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="ResStreak" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Accuracy bar -->
                    <Border Background="{DynamicResource BgCard}" CornerRadius="14"
                            Padding="20,16" Margin="0,0,0,28">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="ACURATEȚE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtMuted}"/>
                                <TextBlock x:Name="ResAccuracy" Text="—%"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource TxtPrimary}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="8" CornerRadius="4"
                                    Background="{DynamicResource BgNavHover}">
                                <Border x:Name="AccuracyBar" Height="8" CornerRadius="4"
                                        Background="#22C55E" HorizontalAlignment="Left"
                                        Width="0"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Saving indicator -->
                    <TextBlock x:Name="TxtSaving" Text="💾 Se salvează activitatea..."
                               FontSize="12" Foreground="{DynamicResource TxtMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,20"
                               Visibility="Visible"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="🔄  Joacă din nou"
                                Click="BtnPlayAgain_Click"
                                Background="{DynamicResource AccentPrimary}"
                                Foreground="White" FontSize="14" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Padding="28,12" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="← Dashboard"
                                Click="BtnBack_Click"
                                Background="{DynamicResource AccentSecBg}"
                                Foreground="{DynamicResource AccentSecFg}"
                                FontSize="14" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand" Padding="28,12">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentSecHov}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>
